rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return resource.data.ownerId == request.auth.uid;
    }

    function isCollaborator(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
    }

    function hasEditorRole(projectId) {
      let collab = get(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
      return collab.data.role == 'editor';
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read:  if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Projects ──────────────────────────────────────────────────────────────

    match /projects/{projectId} {
      // Lecture : propriétaire ou collaborateur
      allow read: if isAuthenticated() &&
                     (isOwner(resource) || isCollaborator(projectId));

      // Création : tout utilisateur connecté (devient propriétaire)
      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid;

      // Mise à jour : propriétaire ou collaborateur avec rôle editor
      allow update: if isAuthenticated() &&
                       (isOwner(resource) || hasEditorRole(projectId));

      // Suppression : propriétaire uniquement
      allow delete: if isAuthenticated() && isOwner(resource);

      // ── Collaborators ──────────────────────────────────────────────────────

      match /collaborators/{collaboratorUid} {
        // Lecture : propriétaire ou le collaborateur lui-même
        allow read: if isAuthenticated() &&
                       (get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
                        request.auth.uid == collaboratorUid);

        // Ajout/suppression : propriétaire du projet uniquement
        allow write: if isAuthenticated() &&
                        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // ── Gallery (NanoBana) ─────────────────────────────────────────────────────

    match /users/{uid}/gallery/{imageId} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Excel Data ────────────────────────────────────────────────────────────

    match /excel_data/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── Taxonomies ────────────────────────────────────────────────────────────

    match /taxonomies/{taxonomyId} {
      allow read:   if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
