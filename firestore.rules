rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return resource.data.ownerId == request.auth.uid;
    }

    function isCollaborator(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
    }

    function hasEditorRole(projectId) {
      let collab = get(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(request.auth.uid));
      return collab.data.role == 'editor';
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read:  if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Projects ──────────────────────────────────────────────────────────────

    match /projects/{projectId} {
      // Lecture : propriétaire ou collaborateur
      allow read: if isAuthenticated() &&
                     (isOwner(resource) || isCollaborator(projectId));

      // Création : tout utilisateur connecté (devient propriétaire)
      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid;

      // Mise à jour : propriétaire ou collaborateur avec rôle editor
      allow update: if isAuthenticated() &&
                       (isOwner(resource) || hasEditorRole(projectId));

      // Suppression : propriétaire uniquement
      allow delete: if isAuthenticated() && isOwner(resource);

      // ── Gallery (projet) ─────────────────────────────────────────────────

      match /gallery/{imageId} {
        allow read:  if isAuthenticated() &&
                        (isOwner(get(/databases/$(database)/documents/projects/$(projectId))) ||
                         isCollaborator(projectId));
        allow create: if isAuthenticated() &&
                         (isOwner(get(/databases/$(database)/documents/projects/$(projectId))) ||
                          hasEditorRole(projectId));
        allow update, delete: if isAuthenticated() &&
                                 (isOwner(get(/databases/$(database)/documents/projects/$(projectId))) ||
                                  hasEditorRole(projectId));
      }

      // ── Collaborators ──────────────────────────────────────────────────────

      match /collaborators/{collaboratorUid} {
        // Lecture : propriétaire ou le collaborateur lui-même
        allow read: if isAuthenticated() &&
                       (get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
                        request.auth.uid == collaboratorUid);

        // Ajout/suppression : propriétaire du projet uniquement
        allow write: if isAuthenticated() &&
                        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // ── Gallery (NanoBana) ─────────────────────────────────────────────────────

    match /users/{uid}/gallery/{imageId} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Excel Data ────────────────────────────────────────────────────────────

    match /excel_data/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── PIM Projects ─────────────────────────────────────────────────────────
    // Projet PIM = doc dans `pim_projects` avec sous-collection `products`.
    // Le doc projet contient userId (propriétaire). Les products héritent des
    // permissions du parent via lookup.

    match /pim_projects/{projectId} {
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Sous-collection products : autorisé si l'utilisateur possède le projet parent.
      // Note: lors de la création (avant que le parent existe), on autorise si le parent
      // est en cours d'écriture par le même user (le batch écrit parent + products).
      match /products/{productId} {
        allow read, write: if isAuthenticated() && (
          (exists(/databases/$(database)/documents/pim_projects/$(projectId)) &&
           get(/databases/$(database)/documents/pim_projects/$(projectId)).data.userId == request.auth.uid)
          ||
          // Pendant la création du projet (parent pas encore committé) : autoriser si le user
          // matchera userId du parent en cours d'écriture. On ne peut pas vérifier le parent
          // dans le même batch, donc fallback : autoriser tout user authentifié à créer/écrire
          // s'il n'y a pas encore de parent. Audit léger via la règle parent qui exigera
          // userId == auth.uid au moment du commit du batch.
          !exists(/databases/$(database)/documents/pim_projects/$(projectId))
        );
      }
    }

    // ── Briefs ────────────────────────────────────────────────────────────────

    match /briefs/{briefId} {
      allow read:   if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      // Sous-collection : images générées
      match /images/{imageId} {
        allow read, write: if isAuthenticated() &&
                              get(/databases/$(database)/documents/briefs/$(briefId)).data.ownerId == request.auth.uid;
      }
    }

    // ── Taxonomies ────────────────────────────────────────────────────────────

    match /taxonomies/{taxonomyId} {
      allow read:   if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // ── DAM Assets ────────────────────────────────────────────────────────────

    // DAM Assets — lecture pour tous les users auth, écriture par le créateur
    match /dam_assets/{assetId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.addedBy == request.auth.uid;
    }

    // DAM Collections — lecture pour tous les users auth, écriture par owner
    match /dam_collections/{collectionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // DAM Favorites — chaque user gère ses propres favoris
    match /dam_favorites/{favId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // DAM Variants — versions éditées d'images, privées à chaque user
    match /dam_variants/{variantId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // DAM Popular Searches — lecture seule pour les users auth
    match /dam_popular_searches/{docId} {
      allow read: if request.auth != null;
    }

    // ── Scraping Templates ──────────────────────────────────────────────────
    // Templates de scraping par fournisseur — lecture/écriture pour tous les
    // utilisateurs authentifiés (ressources partagées entre les comptes du PIM).
    match /scrapingTemplates/{templateId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Scraping Rules ──────────────────────────────────────────────────────
    // Document unique `scrapingRules/global` : markdown partagé décrivant les
    // règles rédactionnelles du scraping. Lecture/écriture pour tous les users
    // authentifiés (édité via l'onglet Règles du Scraping Hub).
    match /scrapingRules/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── AI Usage tracking — agrégat mensuel par user ────────────────────────
    // Document `aiUsage/{uid}_{YYYY-MM}` accumulant tokens/coût par provider.
    // Lecture autorisée uniquement si docId préfixé par l'UID du caller (cf
    // useUsageStats qui fait getDoc(`${uid}_${month}`)). Écriture (create/update
    // via setDoc merge depuis recordAiUsage) requiert ownerId === auth.uid.
    match /aiUsage/{docId} {
      allow read:   if request.auth != null && docId.matches('^' + request.auth.uid + '_\\d{4}-\\d{2}$');
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid
                                            && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
