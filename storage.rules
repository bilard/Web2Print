rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Assets projet (images/links, fonts) — accès aux utilisateurs connectés
    // qui sont propriétaires du projet (vérifié via Firestore)
    // Images de briefs (Nano Banana) — accès au propriétaire du brief
    match /briefs/{briefId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /projects/{projectId}/{allPaths=**} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // DAM — Animations HTML/CSS/JS (ZIP générés côté client par exportHtmlZip).
    // Privées par utilisateur, taille max 50 MB pour couvrir les compositions
    // multi-scènes enrichies avec images IA inline.
    match /dam/html-animations/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType == 'application/zip';
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // DAM images (règle générique : doit rester APRÈS la règle html-animations
    // spécifique sinon Firebase prend la première qui matche et rejette les ZIP).
    match /dam/{assetId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // DAM Variants — versions éditées, privées à chaque user
    match /dam-variants/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Vidéos générées (hf-render-service uploade via admin SDK).
    // Le client peut lire, supprimer et mettre à jour les métadonnées
    // (Content-Disposition pour le nom de fichier au téléchargement).
    match /videos/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Captures (SVG/PNG) envoyées par le client au pipeline vidéo.
    // Privées par utilisateur ; le hf-render-service y accède via admin SDK.
    match /video-captures/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
