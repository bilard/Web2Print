rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Assets projet (images/links, fonts) — accès aux utilisateurs connectés
    // qui sont propriétaires du projet (vérifié via Firestore)
    // Images de briefs (Nano Banana) — accès au propriétaire du brief
    match /briefs/{briefId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /projects/{projectId}/{allPaths=**} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // DAM images
    match /dam/{assetId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
