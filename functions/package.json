    "@sparticuz/chromium": "^147.0.0",
    "cheerio": "^1.0.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "puppeteer-core": "^24.40.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "typescript": "^5.6.3"
  },
  "private": true
