    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "puppeteer-core": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "private": true
}
